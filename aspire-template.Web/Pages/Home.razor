@page "/"

<PageTitle>Home</PageTitle>

<FluentDesignTheme Mode="DesignThemeModes.Dark" />

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; gap: 24px;">

    <FluentIcon Value="@(new Icons.Regular.Size48.BuildingFactory())" Color="Color.Accent" />

    <FluentLabel Typo="Typography.H1">
        Under Construction
    </FluentLabel>

    <FluentLabel Typo="Typography.Body" Alignment="HorizontalAlignment.Center" Style="max-width: 480px; opacity: 0.7;">
        We're building something great. Check back soon.
    </FluentLabel>

    <FluentBadge Appearance="Appearance.Neutral">
        Coming Soon
    </FluentBadge>

</div>